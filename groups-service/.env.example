PORT=8082
# En producción usa el Supavisor *transaction pooler* de Supabase (puerto 6543),
# NO la conexión directa (5432): multiplexa conexiones para aguantar carga
# concurrente sin agotar el cupo de Supabase free. El código usa
# QueryExecModeExec (sin prepared statements) para ser compatible con el pooler.
# Formato: postgresql://postgres.<ref>:<pass>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://user:password@host:5432/db
# Tamaño máximo del pool por servicio (tunéalo por rampa de k6). Default: 10.
DB_MAX_CONNS=10
MAX_GROUP_SIZE=8
HABITS_SERVICE_URL=https://your-habits-service.onrender.com
# Secreto interno servicio-a-servicio (mismo valor en groups/habits/realtime).
# Genera uno con: openssl rand -hex 32
INTERNAL_TOKEN=
