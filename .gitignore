# Environment files (las plantillas .env.example SÍ se versionan)
.env
.env.*
!.env.example

# Go
bin/
# coverage / perfiles de go test y binarios de test compilados
*.out
*.test

# Node / Frontend
# node_modules en cualquier nivel, no solo frontend/
node_modules/
frontend/dist/
frontend/.vite/
# salida de vitest --coverage
coverage/

# Tooling / caché local (Docker monta estos al verificar Go)
.gocache/
.gomodcache/
.npmcache/

# Docker / logs
*.log

# Load tests: loadtest_groups.json es por-entorno (lo regenera seed.sh).
# Los resultados SÍ se versionan (reproducibilidad del paper), EXCEPTO los
# datapoints crudos de k6 (--raw), que pesan cientos de MB.
load-tests/loadtest_groups.json
load-tests/results/**/raw.csv
# Salidas de analyze_results.py (regenerables desde results/)
load-tests/analysis/

# IDE
.vscode/
.idea/
*.swp

# Claude Code
.claude/
.agent/
.agents/

# OS
.DS_Store
Thumbs.db
