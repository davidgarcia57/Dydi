# Variables de entorno para desarrollo local con docker-compose
# Copia este archivo como .env en la raíz del proyecto y llena los valores.
#
# Dónde obtenerlas: https://supabase.com/dashboard
#   → selecciona tu proyecto → Settings → API

# JWT Secret: Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Project URL: Settings → API → Project URL
VITE_SUPABASE_URL=https://xxxx.supabase.co

# Anon Key: Settings → API → anon public
VITE_SUPABASE_ANON_KEY=your-anon-key
