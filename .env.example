# Variables de entorno para desarrollo local con docker-compose.
# Copia este archivo como .env en la raíz del proyecto y llena los valores.
# Consigue todos los valores en: Supabase Dashboard → Settings → API / Database

# ── Supabase Auth ─────────────────────────────────────────────────────────────

# JWT secret del proyecto. api-gateway lo usa para validar tokens.
# Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=

# JWKS URL del proyecto. Formato fijo — solo cambia el project ref.
# Settings → API → Project URL (toma el subdominio)
SUPABASE_JWKS_URL=https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json

# ── Supabase para el frontend ─────────────────────────────────────────────────

# Settings → API → Project URL
VITE_SUPABASE_URL=https://<project-ref>.supabase.co

# Settings → API → Project API Keys → anon (public)
VITE_SUPABASE_ANON_KEY=

# ── Base de datos (Supabase PostgreSQL) ───────────────────────────────────────

# Settings → Database → Connection string → URI
# Usa la conexión directa (no el pooler) para compatibilidad con pgx.
# Asegúrate de reemplazar [YOUR-PASSWORD] con la contraseña del proyecto.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.<project-ref>.supabase.co:5432/postgres

# ── Secreto interno servicio-a-servicio ───────────────────────────────────────
# MISMO valor en api-gateway, groups, habits y realtime. El gateway lo estampa en
# cada petición proxeada y los servicios la exigen, de modo que solo se puede
# llegar al backend a través del gateway (que ya validó el JWT). También protege
# los endpoints /internal/*. Los servicios NO arrancan sin él.
# Genera uno con: openssl rand -hex 32
INTERNAL_TOKEN=

# ── Secreto para Wake Up Cron ──────────────────────────────────────────────────
# Usado por el cron externo para despertar los servicios. El cron debe hacer un POST a /ops/wake
# con el header X-Wake-Token igual a este valor.
WAKE_TOKEN=

# ── Pruebas de estrés (load-tests/, opcional) ─────────────────────────────────
# Cuenta DEDICADA de pruebas (regístrala en la app; no uses tu cuenta personal:
# el seed le cuelga ~1000 grupos). Con esto seed.sh resuelve el uuid solo y
# token.sh acuña JWTs frescos sin copiar nada del navegador.
LOADTEST_EMAIL=
LOADTEST_PASSWORD=

# URLs públicas de Render (para que run_experiment.sh no las pida por args).
LOADTEST_GATEWAY_URL=
LOADTEST_GROUPS_URL=
LOADTEST_HABITS_URL=
LOADTEST_REALTIME_URL=
