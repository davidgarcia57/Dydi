# Variables de entorno para desarrollo local con docker-compose.
# Copia este archivo como .env en la raíz del proyecto y llena los valores.
# Consigue todos los valores en: Supabase Dashboard → Settings → API / Database

# ── Supabase Auth ─────────────────────────────────────────────────────────────

# JWT secret del proyecto. api-gateway lo usa para validar tokens.
# Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=

# JWKS URL del proyecto. Formato fijo — solo cambia el project ref.
# Settings → API → Project URL (toma el subdominio)
SUPABASE_JWKS_URL=https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json

# ── Supabase para el frontend ─────────────────────────────────────────────────

# Settings → API → Project URL
VITE_SUPABASE_URL=https://<project-ref>.supabase.co

# Settings → API → Project API Keys → anon (public)
VITE_SUPABASE_ANON_KEY=

# ── Base de datos (Supabase PostgreSQL) ───────────────────────────────────────

# Settings → Database → Connection string → URI
# Usa la conexión directa (no el pooler) para compatibilidad con pgx.
# Asegúrate de reemplazar [YOUR-PASSWORD] con la contraseña del proyecto.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.<project-ref>.supabase.co:5432/postgres

# ── Secreto interno servicio-a-servicio ───────────────────────────────────────
# MISMO valor en groups, habits y realtime (NO en api-gateway). Protege los
# endpoints /internal/*. Genera uno con: openssl rand -hex 32
INTERNAL_TOKEN=
