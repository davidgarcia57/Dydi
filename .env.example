# Variables de entorno para desarrollo local con docker-compose.
# Copia este archivo como .env en la raiz del proyecto.

# Desarrollo local con Supabase CLI:
# 1. supabase init
# 2. supabase start
# 3. supabase status
# 4. Copia aqui el API URL, anon key y JWT secret que imprime el CLI.

# JWT secret local de Supabase. api-gateway lo usa para validar tokens.
SUPABASE_JWT_SECRET=copy-from-supabase-status

# JWKS local de Supabase Auth. api-gateway lo usa cuando Auth emite tokens ES256.
SUPABASE_JWKS_URL=http://host.docker.internal:54321/auth/v1/.well-known/jwks.json

# API URL local de Supabase Auth. El frontend lo usa desde el navegador.
VITE_SUPABASE_URL=http://127.0.0.1:54321

# Anon key local de Supabase. Es publica, pero debe coincidir con el JWT secret local.
VITE_SUPABASE_ANON_KEY=copy-from-supabase-status

# Produccion:
# Usa los valores de Dashboard -> Settings -> API en tu proyecto de Supabase.
